# openssl rand -base64 32
AUTH_SECRET=replace_with_long_random_string
AUTH_URL=http://localhost:3000

# Neon (Vercel integration): DATABASE_URL = pooled, DATABASE_URL_UNPOOLED = direct — both are set for you.
# Local dev: copy "pooled" + "direct" from Neon dashboard → Connect (https://neon.com/docs/connect/connection-pooling).
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require

# API key from Resend (Auth.js convention). Plain RESEND_API_KEY also works.
AUTH_RESEND_KEY=replace_with_resend_api_key

# Must use a verified domain (e.g. noreply@yourdomain.com). Resend rejects other recipients until then.
AUTH_RESEND_FROM="Hebrew Game <noreply@topupcredits.com>"
